# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database URL (SQLite, PostgreSQL, or other)
# For SQLite: ./data/subscriptions.db
# For PostgreSQL: postgresql://user:password@localhost:5432/touchpoint
DATABASE_URL=./data/subscriptions.db

# Google OAuth Token Validation
GOOGLE_TOKEN_INFO_URL=https://www.googleapis.com/oauth2/v1/tokeninfo
