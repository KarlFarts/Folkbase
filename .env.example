# ============================================
# Touchpoint CRM - Environment Configuration
# ============================================
#
# This file contains all the environment variables needed to run Touchpoint CRM.
# Copy this file to .env and fill in your actual values.
#
# IMPORTANT: Never commit your .env file to version control!
# The .env file is already in .gitignore to protect your credentials.
#
# For detailed setup instructions, see SETUP_GUIDE.md
#


# ============================================
# GOOGLE SHEETS CONFIGURATION
# ============================================
#
# Google Sheets serves as the database for Touchpoint CRM.
# You'll need both a Sheet ID and OAuth Client ID.
#
# Required: YES
# Free Tier: YES (Google Sheets is free)
# Documentation: https://developers.google.com/sheets/api
#

# -------------------
# Google Sheet ID
# -------------------
# This is your Google Sheet's unique identifier.
#
# How to find it:
# 1. Open your Touchpoint CRM Google Sheet
# 2. Look at the URL: https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
# 3. Copy the SHEET_ID_HERE part (between /d/ and /edit)
#
# Example: 1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms
#
# Template: Use the template in SETUP_GUIDE.md to create your sheet
#
VITE_GOOGLE_SHEETS_ID=your_google_sheet_id_here

# -------------------
# Google OAuth Client ID
# -------------------
# This allows users to sign in with Google and access Sheets.
#
# How to get it:
# 1. Go to https://console.cloud.google.com
# 2. Create a new project or select existing
# 3. Enable Google Sheets API (APIs & Services > Library)
# 4. Go to APIs & Services > Credentials
# 5. Create OAuth 2.0 Client ID (Web application)
# 6. Add authorized origins:
#    - http://localhost:3000 (for development)
#    - https://your-domain.com (for production)
# 7. Copy the Client ID (looks like: xxxxx.apps.googleusercontent.com)
#
# Example: 123456789012-abc123def456.apps.googleusercontent.com
#
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com


# ============================================
# DEVELOPMENT MODE (Optional)
# ============================================
#
# Enable development environment with mock authentication and local test data.
# When enabled, you don't need Google credentials - the app
# will use mock data stored in localStorage.
#
# Required: NO (only needed for development)
# Default: false
# Documentation: See docs/DEV_ENVIRONMENT.md
#
# To use:
# 1. Set VITE_DEV_MODE=true
# 2. Restart your development server (npm start)
# 3. App will auto-login with mock user and load test contacts
# 4. Use the "DEV" button in navbar to switch user roles
# 5. Use Dev Tools panel (bottom-left) to manage test data
#

VITE_DEV_MODE=false


# ============================================
# BILLING & SUBSCRIPTION (Optional)
# ============================================
#
# Backend API URL for subscription/billing management.
# If not set, the app will default to free tier for all users.
#
# Required: NO (only if using premium features)
# Default: http://localhost:3001/api
#
# For production, point to your deployed billing server:
# VITE_BILLING_API_URL=https://billing.yourdomain.com/api
#

VITE_BILLING_API_URL=http://localhost:3001/api


# ============================================
# OPTIONAL: ADDITIONAL CONFIGURATION
# ============================================

# -------------------
# Application Settings
# -------------------
# These are optional and have sensible defaults in the code.

# Maximum number of contacts to display per page (default: 50)
# VITE_CONTACTS_PER_PAGE=50

# Token refresh interval in minutes (default: 50)
# VITE_TOKEN_REFRESH_INTERVAL=50

# Follow-up reminder threshold in days (default: 30)
# VITE_FOLLOWUP_DAYS=30


# ============================================
# DEVELOPMENT NOTES
# ============================================
#
# After updating this file:
# 1. Restart your development server (npm start)
# 2. Clear your browser cache if experiencing issues
# 3. Check the browser console for any configuration errors
#
# Need help? See SETUP_GUIDE.md for detailed instructions
#
