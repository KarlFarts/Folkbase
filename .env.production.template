# ============================================
# TOUCHPOINT CRM - PRODUCTION CONFIGURATION
# ============================================
# Copy this file to .env.production and fill in your actual values
# NEVER commit .env.production to git!

# ============================================
# ENVIRONMENT MODE
# ============================================
# CRITICAL: Set to false for production!
VITE_DEV_MODE=false

# ============================================
# GOOGLE SHEETS CONFIGURATION
# ============================================
# Google Sheet ID: Found in the URL of your sheet
# https://docs.google.com/spreadsheets/d/[THIS_IS_YOUR_SHEET_ID]/edit
VITE_GOOGLE_SHEETS_ID=your_google_sheet_id_here

# Google OAuth Client ID: From Google Cloud Console > APIs & Services > Credentials
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ============================================
# ERROR REPORTING (OPTIONAL)
# ============================================
# Sentry DSN for error tracking (optional but recommended)
# Get from https://sentry.io/settings/projects/your-project/keys/
# Free tier: 5,000 errors/month
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================
# OPTIONAL SETTINGS
# ============================================
# Contacts per page in list view (default: 50)
# VITE_CONTACTS_PER_PAGE=50

# Token refresh interval in minutes (default: 50)
# VITE_TOKEN_REFRESH_INTERVAL=50

# Followup days threshold (default: 30)
# VITE_FOLLOWUP_DAYS=30

# ============================================
# DEPLOYMENT CHECKLIST
# ============================================
# Before deploying to production:
#
# 1. Security:
#    - [ ] Replace all placeholder values with real credentials
#    - [ ] Verify VITE_DEV_MODE=false
#    - [ ] Ensure this file is NOT committed to git
#    - [ ] Check .gitignore includes .env* files
#
# 2. Google Cloud Setup:
#    - [ ] Create Google Cloud project
#    - [ ] Enable Google Sheets API
#    - [ ] Create OAuth 2.0 credentials
#    - [ ] Add production domain to authorized origins/redirects
#    - [ ] Copy OAuth Client ID above
#
# 3. Google Sheet Setup:
#    - [ ] Create new Google Sheet from template
#    - [ ] Copy Sheet ID from URL
#    - [ ] Verify all required tabs exist
#    - [ ] Set appropriate sharing permissions
#
# 4. Error Reporting (Optional):
#    - [ ] Create Sentry project
#    - [ ] Copy DSN above
#    - [ ] Install Sentry: npm install @sentry/react
#
# 5. Deployment Platform:
#    - [ ] Set all environment variables in platform dashboard
#    - [ ] Configure HTTPS redirect
#    - [ ] Verify custom domain SSL certificate
#    - [ ] Test deployment on staging first
#
# See PRODUCTION_SETUP_GUIDE.md for detailed instructions
